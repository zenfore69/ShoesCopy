<Page x:Class="ShoesNet.Wndows.AuthPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesNet.Wndows"
        mc:Ignorable="d"
      Title="Авторизация"
      Height="450" Width="800"
      MinWidth="800" MinHeight="450">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
        <TextBlock Text="Авторизация" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <TextBlock Text="Логин:"/>
        <TextBox x:Name="TxtBoxLogin" Margin="0,0,0,10" Padding="5"/>
        <TextBlock Text="Пароль:"/>
        <PasswordBox x:Name="PassBox" Margin="0,0,0,20" Padding="5"/>
        <Button Content="Войти" Click="BtnLogin_Click"/>
        <Button Content="Войти как гость" Click="BtnGuest_Click" Background="LightGray"/>
            

    </StackPanel>
</Page>
