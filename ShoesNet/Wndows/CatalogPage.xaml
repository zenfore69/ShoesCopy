<Page x:Class="ShoesNet.Wndows.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShoesNet.Wndows"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Каталог товаров" Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch"
                     TextChanged="FilterData"
                     Grid.Column="0"
                     Margin="5"
                     ToolTip="Поиск по текстовым данным (название, описание и т.д.)"/>

            <ComboBox x:Name="CmbSort"
                      SelectionChanged="FilterData"
                      Grid.Column="1"
                      Margin="5">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По возрастанию количества"/>
                <ComboBoxItem Content="По убыванию количества"/>
            </ComboBox>

            <ComboBox x:Name="CmbFilter"
                      SelectionChanged="FilterData"
                      Grid.Column="2"
                      Margin="5"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="TxtCount" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0,20,0"/>
            <Button x:Name="BtnAddProduct" Content="ДобавитьТовар" Visibility="Collapsed"/>
            <Button x:Name="BtnOrders" Content="Заказы" Visibility="Collapsed" Click="BtnOrders_Click"/>
        </StackPanel>

        <ListView x:Name="LViewProducts"
                  Grid.Row="2"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="LViewProducts_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ProductBorder" BorderThickness="1" BorderBrush="Black" Margin="5" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding ПолныйПутьКФото}" Width="100" Height="100" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="{Binding КатегорияТовара}" FontSize="16"/>
                                    <TextBlock Text=" | " FontSize="16"/>
                                    <TextBlock Text="{Binding НаименованиеТовара}" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>

                                <TextBlock Text="{Binding ОписаниеТовара, StringFormat='Описание товара: {0}'}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding Производитель, StringFormat='Производитель: {0}'}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Поставщик, StringFormat='Поставщик: {0}'}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Цена: " FontSize="16"/>
                                    <TextBlock x:Name="TxtOldPrice" Text="{Binding Цена}" FontSize="16"/>
                                    <TextBlock x:Name="TxtNewPrice"
                                               Text="{Binding ЦенаСоСкидкой, StringFormat=' {0}'}"
                                               Visibility="Collapsed"
                                               Foreground="Black"
                                               FontSize="16"
                                               FontWeight="Bold"/>
                                    <TextBlock Text=" руб." FontSize="16"/>
                                </StackPanel>

                                <TextBlock Text="{Binding ЕдиницаИзмерения, StringFormat='Единица измерения: {0}'}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding КолВоНаСкладе, StringFormat='Количество на складе: {0}'}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding ДействующаяСкидка, StringFormat='Действующая скидка: {0}%'}"/>

                                <Button x:Name="BtnDelete"
                                        Content="Удалить"
                                        Background="Red"
                                        Foreground="White"
                                        Loaded="BtnDelete_Loaded"
                                        Click="BtnDelete_Click"
                                        Margin="0,10,0,0"
                                        Padding="5"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding СкидкаБольше15}" Value="True">
                            <Setter TargetName="ProductBorder" Property="Background" Value="#2E8B57"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding КолВоНаСкладе}" Value="0">
                            <Setter TargetName="ProductBorder" Property="Background" Value="LightBlue"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding ЕстьСкидка}" Value="True">
                            <Setter TargetName="TxtOldPrice" Property="TextDecorations" Value="Strikethrough"/>
                            <Setter TargetName="TxtOldPrice" Property="Foreground" Value="Red"/>
                            <Setter TargetName="TxtNewPrice" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

