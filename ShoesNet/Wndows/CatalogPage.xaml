<Page x:Class="ShoesNet.Wndows.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShoesNet.Wndows"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      MinWidth="900" MinHeight="600"
      Title="Каталог товаров" Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch"
                     TextChanged="FilterData"
                     Grid.Column="0"
                     Margin="5"
                     ToolTip="Поиск по текстовым данным (название, описание и т.д.)"/>

            <ComboBox x:Name="CmbSort"
                      SelectionChanged="FilterData"
                      Grid.Column="1"
                      Margin="5">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По возрастанию количества"/>
                <ComboBoxItem Content="По убыванию количества"/>
            </ComboBox>

            <ComboBox x:Name="CmbFilter"
                      SelectionChanged="FilterData"
                      Grid.Column="2"
                      Margin="5"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="TxtCount" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0,20,0"/>
            <Button x:Name="BtnAddProduct" Content="ДобавитьТовар" Visibility="Collapsed"/>
            <Button x:Name="BtnOrders" Content="Заказы" Visibility="Collapsed" Click="BtnOrders_Click"/>
        </StackPanel>

        <ListView x:Name="LViewProducts"
                  Grid.Row="2"
                  HorizontalContentAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="LViewProducts_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ProductBorder"
                            BorderThickness="2"
                            BorderBrush="Black"
                            Margin="5"
                            Padding="10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Height="250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фото -->
                            <Border Grid.Column="0"
                                    BorderThickness="1"
                                    BorderBrush="Black"
                                    Margin="0,0,10,0"
                                    Padding="6"
                                    CornerRadius="0">
                                <Image Source="{Binding ПолныйПутьКФото}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Width="130"
                                       Height="130"/>
                            </Border>

                            <!-- Основная информация -->
                            <StackPanel Grid.Column="1"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding КатегорияТовара}"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                                <TextBlock Text="{Binding НаименованиеТовара}"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Margin="0,0,0,6"/>

                                <!-- Ограничиваем высоту текста, чтобы карточки оставались одинаковыми по размеру -->
                                <TextBlock Text="{Binding ОписаниеТовара, StringFormat='Описание товара: {0}'}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,2"
                                           TextTrimming="CharacterEllipsis"
                                           Height="54"/>
                                <TextBlock Text="{Binding Производитель, StringFormat='Производитель: {0}'}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Поставщик, StringFormat='Поставщик: {0}'}"
                                           Margin="0,0,0,2"/>

                                <!-- Цена: старая (зачёркнутая при скидке) и итоговая со скидкой -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Цена: " />
                                    <TextBlock x:Name="TxtOldPrice"
                                               Text="{Binding Цена}"
                                               Visibility="Collapsed"
                                               Foreground="Red"/>
                                    <TextBlock x:Name="TxtNewPrice"
                                               Text="{Binding ЦенаСоСкидкой}"
                                               Visibility="Collapsed"
                                               Margin="6,0,0,0"
                                               Foreground="Black"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="руб." Margin="6,0,0,0"/>
                                </StackPanel>

                                <TextBlock Margin="0,0,0,2" Text="{Binding ЕдиницаИзмерения, StringFormat='Единица измерения: {0}'}"/>
                                <TextBlock Margin="0,0,0,2" Text="{Binding КолВоНаСкладе, StringFormat='Количество на складе: {0}'}"/>
                            </StackPanel>

                            <!-- Скидка и кнопка удаления -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Stretch">
                                <Border BorderThickness="1" BorderBrush="Black" Padding="6" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding ДействующаяСкидка, StringFormat='Действующая скидка: {0}%'}"
                                               FontWeight="Bold"/>
                                </Border>

                                <Button x:Name="BtnDelete"
                                        Content="Удалить"
                                        Background="#00FA9A"
                                        Foreground="White"
                                        Loaded="BtnDelete_Loaded"
                                        Click="BtnDelete_Click"
                                        Margin="0"
                                        Padding="5"
                                        VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding СкидкаБольше15}" Value="True">
                            <Setter TargetName="ProductBorder" Property="Background" Value="#2E8B57"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding КолВоНаСкладе}" Value="0">
                            <Setter TargetName="ProductBorder" Property="Background" Value="LightBlue"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding ЕстьСкидка}" Value="True">
                            <Setter TargetName="TxtOldPrice" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="TxtOldPrice" Property="TextDecorations" Value="Strikethrough"/>
                            <Setter TargetName="TxtOldPrice" Property="Foreground" Value="Red"/>
                            <Setter TargetName="TxtNewPrice" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

